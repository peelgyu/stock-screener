{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "startCommand": "gunicorn app:app --workers 2 --timeout 90 --bind 0.0.0.0:$PORT --access-logfile - --error-logfile -",
    "healthcheckPath": "/api/cache/stats",
    "healthcheckTimeout": 30,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 5
  }
}
